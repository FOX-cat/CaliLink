<Window x:Class="WpfSerialTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfSerialTool"
        mc:Ignorable="d"
        Title="调试控制台"
        Height="900" Width="1320"
        WindowStartupLocation="CenterScreen"
        Background="#0B0F17">

    <Window.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Background" Value="#151B26"/>
            <Setter Property="BorderBrush" Value="#2A3344"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="TechButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#1E88E5"/>
            <Setter Property="BorderBrush" Value="#42A5F5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#42A5F5"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#3A4250"/>
                    <Setter Property="BorderBrush" Value="#4A5568"/>
                    <Setter Property="Foreground" Value="#9AA4B2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource TechButtonStyle}">
            <Setter Property="Background" Value="#E53935"/>
            <Setter Property="BorderBrush" Value="#EF5350"/>
        </Style>

        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="#1C2330"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="4"/>
        </Style>

        <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1C2330"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TextLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C8D1DC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="4,6,4,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MiniButtonStyle" TargetType="Button" BasedOn="{StaticResource TechButtonStyle}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="2"/>
        </Style>

        <Style x:Key="DarkDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DarkDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#233044"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1D4ED8"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="#0D1320"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#233044"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#111827"/>
            <Setter Property="AlternatingRowBackground" Value="#0F172A"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#233044"/>
            <Setter Property="VerticalGridLinesBrush" Value="#233044"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserResizeColumns" Value="True"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource DarkDataGridColumnHeaderStyle}"/>
            <Setter Property="CellStyle" Value="{StaticResource DarkDataGridCellStyle}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="95"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题 + 状态监视 + 时钟 -->
        <Border Grid.Row="0"
                CornerRadius="14"
                Background="#111827"
                BorderBrush="#233044"
                BorderThickness="1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="460"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧标题 -->
                <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="调试控制台"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"/>
                    <TextBlock Text="Serial Calibration Control Center"
                               Foreground="#5EEAD4"
                               FontSize="13"/>
                </StackPanel>

                <!-- 中间状态监视 -->
                <Border Grid.Column="1"
                        Margin="10,10,10,10"
                        Padding="12,8"
                        CornerRadius="10"
                        Background="#0F172A"
                        BorderBrush="#233044"
                        BorderThickness="1"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="88"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="88"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="42"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="42"/>
                        </Grid.ColumnDefinitions>

                        <!-- 串口 -->
                        <Ellipse x:Name="ledPort"
                                 Grid.Column="0"
                                 Width="14"
                                 Height="14"
                                 Fill="Gray"
                                 VerticalAlignment="Center"
                                 Margin="0,0,6,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="串口"
                                       Foreground="White"
                                       FontSize="12"/>
                            <TextBlock x:Name="txtPortStatus"
                                       Text="未连接"
                                       Foreground="#9CA3AF"
                                       FontSize="11"/>
                        </StackPanel>

                        <!-- 校准 -->
                        <Ellipse x:Name="ledCalibrate"
                                 Grid.Column="2"
                                 Width="14"
                                 Height="14"
                                 Fill="Gray"
                                 VerticalAlignment="Center"
                                 Margin="12,0,6,0"/>
                        <StackPanel Grid.Column="3" VerticalAlignment="Center">
                            <TextBlock Text="校准"
                                       Foreground="White"
                                       FontSize="12"/>
                            <TextBlock x:Name="txtCalibrateStatus"
                                       Text="待机"
                                       Foreground="#9CA3AF"
                                       FontSize="11"/>
                        </StackPanel>

                        <!-- TX -->
                        <Ellipse x:Name="ledSend"
                                 Grid.Column="4"
                                 Width="14"
                                 Height="14"
                                 Fill="Gray"
                                 VerticalAlignment="Center"
                                 Margin="12,0,6,0"/>
                        <TextBlock Grid.Column="5"
                                   Text="TX"
                                   Foreground="#9CA3AF"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>

                        <!-- RX -->
                        <Ellipse x:Name="ledReceive"
                                 Grid.Column="6"
                                 Width="14"
                                 Height="14"
                                 Fill="Gray"
                                 VerticalAlignment="Center"
                                 Margin="12,0,6,0"/>
                        <TextBlock Grid.Column="7"
                                   Text="RX"
                                   Foreground="#9CA3AF"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- 右侧时钟 -->
                <TextBlock x:Name="txtClock"
                           Grid.Column="2"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="#93C5FD"
                           FontSize="18"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧控制区-->
            <StackPanel>
                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="串口配置"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="Bold"/>

                        <TextBlock Text="串口号" Style="{StaticResource TextLabelStyle}"/>
                        <ComboBox x:Name="cmbPorts" Style="{StaticResource DarkComboBoxStyle}"/>

                        <TextBlock Text="波特率" Style="{StaticResource TextLabelStyle}"/>
                        <ComboBox x:Name="cmbBaudRate" Style="{StaticResource DarkComboBoxStyle}">
                            <ComboBoxItem Content="9600"  IsSelected="True"/>
                            <ComboBoxItem Content="19200"/>
                            <ComboBoxItem Content="38400"/>
                            <ComboBoxItem Content="57600"/>
                            <ComboBoxItem Content="115200"/>
                        </ComboBox>

                        <UniformGrid Columns="2" Margin="0,8,0,0">
                            <Button x:Name="btnRefreshPorts"
                                        Content="刷新串口"
                                        Style="{StaticResource TechButtonStyle}"
                                        Click="btnRefreshPorts_Click"/>
                            <Button x:Name="btnOpenClose"
                                        Content="打开串口"
                                        Style="{StaticResource TechButtonStyle}"
                                        Click="btnOpenClose_Click"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="单站控制"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="Bold"/>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="38"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="38"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                           Text="从站地址"
                                           Style="{StaticResource TextLabelStyle}"
                                           Margin="4,0,4,0"/>

                            <Button Grid.Column="1"
                                        x:Name="btnSlaveMinus"
                                        Content="-"
                                        Style="{StaticResource MiniButtonStyle}"
                                        Click="btnSlaveMinus_Click"
                                        IsEnabled="False"/>

                            <TextBox Grid.Column="2"
                                         x:Name="txtSlaveId"
                                         Text="1"
                                         HorizontalContentAlignment="Center"
                                         Style="{StaticResource DarkTextBoxStyle}"/>

                            <Button Grid.Column="3"
                                        x:Name="btnSlavePlus"
                                        Content="+"
                                        Style="{StaticResource MiniButtonStyle}"
                                        Click="btnSlavePlus_Click"
                                        IsEnabled="False"/>

                            <Button Grid.Column="4"
                                        x:Name="btnQuerySlave"
                                        Content="问询从站"
                                        Style="{StaticResource TechButtonStyle}"
                                        Click="btnQuerySlave_Click"
                                        IsEnabled="False"/>
                        </Grid>

                        <UniformGrid Columns="2" Margin="0,8,0,0">
                            <Button x:Name="btnStartCalibrate"
                                        Content="开始校准"
                                        Style="{StaticResource TechButtonStyle}"
                                        Click="btnStartCalibrate_Click"
                                        IsEnabled="False"/>

                            <Button x:Name="btnStopCalibrate"
                                        Content="停止校准"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Click="btnStopCalibrate_Click"
                                        IsEnabled="False"/>
                        </UniformGrid>

                        <Button x:Name="btnClearLog"
                                    Content="清空接收区"
                                    Style="{StaticResource TechButtonStyle}"
                                    Click="btnClearLog_Click"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="批量轮询"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="Bold"/>

                        <TextBlock Text="从站列表（例如：1,2,3,5）" Style="{StaticResource TextLabelStyle}"/>
                        <TextBox x:Name="txtSlaveList"
                                     Text="1,2,3"
                                     Style="{StaticResource DarkTextBoxStyle}"/>

                        <TextBlock Text="轮询间隔(ms)" Style="{StaticResource TextLabelStyle}"/>
                        <TextBox x:Name="txtPollInterval"
                                     Text="500"
                                     Style="{StaticResource DarkTextBoxStyle}"/>

                        <UniformGrid Columns="2" Margin="0,8,0,0">
                            <Button x:Name="btnStartPolling"
                                        Content="开始轮询"
                                        Style="{StaticResource TechButtonStyle}"
                                        Click="btnStartPolling_Click"
                                        IsEnabled="False"/>
                            <Button x:Name="btnStopPolling"
                                        Content="停止轮询"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Click="btnStopPolling_Click"
                                        IsEnabled="False"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 右侧显示区 -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="340"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="从站实时数据"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>

                        <DataGrid x:Name="dgSlaveData"
                                  Grid.Row="1"
                                  Margin="0,10,0,0"
                                  Style="{StaticResource DarkDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="从站地址" Binding="{Binding SlaveId}" Width="90"/>
                                <DataGridTextColumn Header="横滚角(°)" Binding="{Binding RollDisplay}" Width="110"/>
                                <DataGridTextColumn Header="俯仰角(°)" Binding="{Binding PitchDisplay}" Width="110"/>
                                <DataGridTextColumn Header="航向角(°)" Binding="{Binding YawDisplay}" Width="110"/>
                                <DataGridTextColumn Header="温度(℃)" Binding="{Binding TemperatureDisplay}" Width="110"/>
                                <DataGridTextColumn Header="更新时间" Binding="{Binding UpdateTime}" Width="160"/>

                                <DataGridTextColumn Header="原始HEX"
                                                    Binding="{Binding RawHex}"
                                                    Width="260"
                                                    MinWidth="220">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="TextWrapping" Value="NoWrap"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="ToolTip" Value="{Binding RawHex}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="40"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0">
                            <TextBlock Text="接收数据 / 日志"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       DockPanel.Dock="Left"/>
                        </DockPanel>

                        <TextBox x:Name="txtReceiveArea"
                                 Grid.Row="1"
                                 Margin="0,10,0,0"
                                 Background="#0D1320"
                                 Foreground="#7CFC98"
                                 BorderBrush="#233044"
                                 BorderThickness="1"
                                 FontFamily="Consolas"
                                 FontSize="14"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="Wrap"
                                 IsReadOnly="True"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>